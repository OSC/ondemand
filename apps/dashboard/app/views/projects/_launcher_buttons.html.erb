<%-
  disabled = !@valid_project
  disabled_class = disabled ? 'disabled' : ''
  launch_title = t('dashboard.jobs_launchers_submit_launcher_title', name: launcher.title)
  show_title = t('dashboard.jobs_launchers_show_form', name: launcher.title)
  edit_title = t('dashboard.jobs_launchers_edit', name: launcher.title)
  delete_title = t('dashboard.jobs_launchers_delete', name: launcher.title)
  remove_delete_button = @remove_delete_button
  show_job_info_button = @show_job_info_button
-%>

<div class="row">
  <div class="col">
    <%= button_to(
      submit_project_launcher_path(@project.id, launcher.id),
      class: 'btn btn-success launcher-button',
      title: launch_title,
      disabled: disabled,
      params: launcher.quick_launch_params,
      id: "launch_#{launcher.id}"
    ) do
    %>
      <%= I18n.t('dashboard.launch') %>
    <%- end %>
  </div>

  <div class="col">
    <%= link_to(
      project_launcher_path(@project.id, launcher.id),
      class: "btn btn-info launcher-button #{disabled_class}",
      aria: {label: show_title},
      id: "show_#{launcher.id}"
      ) do
    %>
      <%= I18n.t('dashboard.show') %>
    <%- end -%>

  </div>
</div>
<div class="row">
  <% if launcher.editable? %>
    <div class="col">
      <%= link_to(
        edit_project_launcher_path(@project.id, launcher.id),
        class: "btn btn-primary launcher-button #{disabled_class}",
        id: "edit_#{launcher.id}",
        aria: {label: edit_title}) do
      %>
        <%= I18n.t('dashboard.edit') %>
      <%- end %>
    </div>

    <% unless remove_delete_button %>
      <div class="col">
        <%= button_to(
          project_launcher_path(@project.id, launcher.id),
          id: "delete_#{launcher.id}",
          class: "btn btn-danger launcher-button",
          aria: {label: delete_title},
          data: { confirm: I18n.t('dashboard.jobs_launchers_delete_script_confirmation') },
          method: :delete) do
        %>
          <%= I18n.t('dashboard.delete') %>
        <%- end -%>
      </div>
    <% end %>
  <% end %>
  
  <% if show_job_info_button %>
    <div class="col">
      <button
        class="btn btn-secondary launcher-button disabled"
        id="job_info_<%= launcher.id %>"
        data-launcher-id="<%= launcher.id %>"
        disabled
      >
        <%= I18n.t('dashboard.job_info') %>
      </button>
    </div>
  <% end %>
</div>
