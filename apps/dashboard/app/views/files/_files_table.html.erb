<div class="col-md-9">
  <%# TODO put search box ABOVE the breadcrumbs %>
    <ol id="path-breadcrumbs" class="breadcrumb breadcrumb-no-delimiter rounded" role="region" aria-label="Path breadcrumbs">
      <%= render partial: 'breadcrumb', collection: @path.descend, as: :file, locals: { file_count: @path.descend.count, full_path: @path } %>
    </ol>

    <div role="region" aria-label="Directory contents">
      <span id="select_all_label" class="d-none">Select All</span>
      <table class="table table-striped table-condensed w-100" id="directory-contents">
        <caption id="directory-contents_caption" class="sr-only" aria-live='polite'> <%= "Contents of directory #{@path}" %> </caption>
        <thead>
          <tr>
            <th>
              <input type="checkbox" id="select_all" class="file-select" aria-describedby="select_all_label">
              <span class="sr-only">Select</span>
            </th>
            <th>Type</th>
            <th>Name</th>
            <th><span class="sr-only">Actions</span></th>
            <th>Size</th>
            <th>Modified at</th>
            <th>Owner</th>
            <th>Mode</th>
          </tr>
        </thead>
        <tbody>
        </tbody>
      </table>
      <%= render partial: "spinner" %>
    </div>
</div>
