<%= javascript_include_tag 'products_index', nonce: true %>

<% product_class = Product.product_types[@type] %>

<%= render 'breadcrumbs' %>

<p>
  <%= link_to t('dashboard.products_new_app'), new_product_path(type: @type), class: 'btn btn-default' %>
  <span class="float-end">
    <%= render(partial: 'shared/shell_button', locals: { label: t('dashboard.products_launch_shell'), path: product_class.router.base_path.realdirpath }) %>
    <% if Configuration.can_access_files? %>
      <%= link_to t('dashboard.products_launch_files'), OodAppkit.files.url(path: product_class.router.base_path.realdirpath).to_s, class: 'btn btn-default' %>
    <% end %>
  </span>
</p>

<hr />

<table id="productTable" class="table table-striped" data-state-save="true" data-page-length="50" data-order="<%= %([4, "desc"]) %>">
  <thead>
    <tr>
      <th data-orderable="false" data-searchable="false"></th>
      <th><%= t('dashboard.products_dir_name') %></th>
      <th><%= t('dashboard.products_app_details') %></th>
      <th data-orderable="false" data-searchable="false"></th>
      <th><%= t('dashboard.products_last_modified') %></th>
      <th data-orderable="false" data-searchable="false"></th>
      <th data-orderable="false" data-searchable="false"></th>
    </tr>
  </thead>

  <tbody>
    <%= render partial: "product", collection: @products %>
  </tbody>
</table>
