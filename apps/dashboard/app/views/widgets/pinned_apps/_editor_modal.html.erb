<% modal_body = capture do %>
  <p class="text-muted"><%= t('dashboard.pinned_apps_editor_help') %></p>

  <% if dashboard_pinned_app_options.empty? %>
    <div class="alert alert-info mb-0"><%= t('dashboard.pinned_apps_no_available') %></div>
  <% else %>
    <%= form_with url: pinned_apps_path, method: :patch, local: true, id: 'pinned-apps-form' do |form| %>
      <div class="mb-2">
        <label for="pinned-apps-search" class="form-label"><%= t('dashboard.pinned_apps_search') %></label>
        <input id="pinned-apps-search" type="text" class="form-control" placeholder="<%= t('dashboard.pinned_apps_search_placeholder') %>">
      </div>

      <div class="d-flex gap-2 flex-wrap mb-2">
        <button type="button" class="btn btn-sm btn-outline-primary" id="select-all-pinned-apps"><%= t('dashboard.pinned_apps_select_all') %></button>
        <button type="button" class="btn btn-sm btn-outline-secondary" id="clear-all-pinned-apps"><%= t('dashboard.pinned_apps_clear_all') %></button>
      </div>

      <div class="border rounded overflow-auto p-3 ps-4 mb-3">
        <% dashboard_pinned_app_options.each do |title, token| %>
          <div class="form-check pinned-app-checkbox-item mb-2" data-app-title="<%= title.downcase %>" data-app-token="<%= token.downcase %>">
            <%= check_box_tag 'pinned_app_tokens[]', token, dashboard_selected_pinned_app_tokens.include?(token), id: "pinned_app_token_#{token.parameterize}", class: 'form-check-input' %>
            <%= label_tag "pinned_app_token_#{token.parameterize}", title, class: 'form-check-label' %>
          </div>
        <% end %>
      </div>

      <div class="d-flex justify-content-between flex-wrap gap-2">
        <%= link_to t('dashboard.pinned_apps_reset'), pinned_apps_path, method: :delete,
                    data: { confirm: t('dashboard.pinned_apps_reset_confirm'), turbo_method: :delete },
                    class: 'btn btn-outline-danger' %>
        <div class="d-flex gap-2">
          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal"><%= t('dashboard.close') %></button>
          <%= form.submit t('dashboard.pinned_apps_save'), class: 'btn btn-primary' %>
        </div>
      </div>
    <% end %>
  <% end %>
<% end %>

<%= render partial: 'shared/modal', locals: {
  modal_id: 'pinnedAppsModal',
  title_id: 'pinnedAppsModalLabel',
  title: t('dashboard.pinned_apps_editor_title'),
  dialog_classes: 'modal-dialog-scrollable modal-lg',
  body_content: modal_body
} %>
