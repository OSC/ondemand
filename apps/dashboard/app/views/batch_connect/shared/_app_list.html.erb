<%
  safe_title = title.to_s.parameterize.presence || "group"  
  card_dom_id = "bc-app-list-#{safe_title}"
  list_dom_id = "bc-app-list-#{safe_title}-items"
%>
<div class="card collapsible-app-card <%= local_assigns.fetch(:style, "system-and-shared-apps-header") %>" data-collapsible-sidebar-card data-card-id="<%= card_dom_id %>">
  <button
    class="card-header collapsible-app-card-toggle"
    type="button"
    aria-expanded="false"
    aria-controls="<%= list_dom_id %>"
  >
    <span><%= title %></span>
  </button>
  <div id="<%= list_dom_id %>" class="list-group list-group-flush">
  <%-
    OodAppGroup.groups_for(
      apps: apps,
      group_by: local_assigns.fetch(:group_by, :subcategory),
      sort: local_assigns.fetch(:sort, true),
    ).each do |app_group|
  -%>
    <%=
      content_tag(
        "p",
        app_group.title,
        class: "list-group-item mb-0 header border-0"
      ) unless app_group.title.blank?
    %>
    <%=
      render(
        partial: "batch_connect/shared/app_list_item",
        collection: app_group.apps,
        as: :app,
        locals: {
          show_owner: local_assigns.fetch(:show_owner, false),
          current_url: local_assigns[:current_url]
        }
      )
    %>
  <%- end -%>
  </div>
</div>
