<% content_for :title, "#{t('dashboard.module_browser_title')} - #{@user_configuration.dashboard_title}" %>

<h1 class="mb-4 d-flex justify-content-between">
  <%= t('dashboard.module_browser_title') %>
  <span class="h4 text-muted">
    <%= t('dashboard.module_browser_last_updated', last_updated: @modules_last_updated) %>
  </span>
</h1>

<%= render 'toolbar' %>
<%= render 'module_list', modules: @modules %>

<div
  id="module_browser_i18n"
  class="d-none"
  data-copy-text="<%= t('dashboard.module_browser_copy') %>"
  data-copied-text="<%= t('dashboard.module_browser_copied') %>"
  data-showing-results-template="<%= t('dashboard.module_browser_showing_results', count: '%{count}') %>"
></div>

<%= javascript_include_tag 'module_browser', nonce: true %>
